# ─── MoodMap Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values

# ─── LLM Provider Configuration ─────────────────────────────────────────────
# Provider: groq | openai | anthropic | gemini | custom
LLM_PROVIDER=groq

# API key for your chosen provider (GROQ_KEY also accepted for backward compat)
LLM_API_KEY=your_api_key_here
# GROQ_KEY=your_groq_api_key_here  # Legacy: still works if LLM_API_KEY not set

# Optional: override model name (defaults vary by provider)
# LLM_MODEL=llama-3.3-70b-versatile

# Optional: custom base URL (for OpenAI-compatible providers like Together/Fireworks)
# LLM_BASE_URL=https://api.together.xyz/v1/chat/completions

# Optional: LLM request timeout in milliseconds (default: 15000)
# LLM_TIMEOUT_MS=15000

# ─── Server Configuration ───────────────────────────────────────────────────
# PORT=3001

# CORS allowed origins (comma-separated; empty = localhost only in dev)
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://moodmap.example.com

# Rate limit: max requests per IP per minute (default: 30)
# RATE_LIMIT_MAX=30
