# ─── MoodMap Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values

# ─── LLM Provider Configuration ─────────────────────────────────────────────
# Provider: groq | openai | anthropic | gemini | custom
LLM_PROVIDER=groq

# API key for your chosen provider (GROQ_KEY also accepted for backward compat)
LLM_API_KEY=your_api_key_here
# GROQ_KEY=your_groq_api_key_here  # Legacy: still works if LLM_API_KEY not set

# Optional: override model name (defaults vary by provider)
# LLM_MODEL=llama-3.3-70b-versatile

# Optional: custom base URL (for OpenAI-compatible providers like Together/Fireworks)
# LLM_BASE_URL=https://api.together.xyz/v1/chat/completions

# Optional: LLM request timeout in milliseconds (default: 15000)
# LLM_TIMEOUT_MS=15000

# ─── Firebase (real-time community pin sync) ─────────────────────────────────
# Create a project at https://console.firebase.google.com, add a Web app,
# copy the config values below, then enable Firestore Database in the console.
#
# Recommended Firestore security rules (paste in Rules tab):
#   rules_version = '2';
#   service cloud.firestore {
#     match /databases/{database}/documents {
#       match /mood_pins/{pin} {
#         allow read: if true;
#         allow create: if request.resource.data.keys().hasAll(['lat','lng','mood','color','emoji','time','timestamp']);
#         allow update, delete: if false;
#       }
#     }
#   }
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Server Configuration ───────────────────────────────────────────────────
# PORT=3001

# CORS allowed origins (comma-separated; empty = localhost only in dev)
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://moodmap.example.com

# Rate limit: max requests per IP per minute (default: 30)
# RATE_LIMIT_MAX=30
